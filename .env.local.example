# Copy to .env.local and fill in after deploying StreamVault.

# Deployed StreamVault address (from the forge deploy output).
NEXT_PUBLIC_STREAMVAULT_ADDRESS=

# USDC ERC-20 on Arc Testnet — already correct, leave as is.
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Block the contract was deployed at (speeds up event scanning). Optional but
# recommended — copy from the deploy receipt. Defaults to 0 (scan from genesis).
NEXT_PUBLIC_DEPLOY_BLOCK=

# Optional: only needed to connect MOBILE wallets via QR. Free at
# https://dashboard.reown.com . Extension wallets work without it.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
